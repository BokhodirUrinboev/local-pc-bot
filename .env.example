# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=

# Whitelist — faqat ushbu Telegram USER ID'lar botdan foydalana oladi (private va gruppa ichida).
# Vergul bilan ajrating. MAJBURIY: bo'sh qoldirilsa bot ishga TUSHMAYDI (fail-closed) —
# chunki bu ochiq masofaviy shell bo'lib qolardi. Ataylab ochiq qilmoqchi bo'lsangiz,
# quyidagi BOT_ALLOW_ALL_USERS=yes qo'ying (xavfli).
# Misol: ALLOWED_TELEGRAM_IDS=123456789,987654321
ALLOWED_TELEGRAM_IDS=

# (Ixtiyoriy, XAVFLI) ALLOWED_TELEGRAM_IDS bo'sh bo'lsa ham botni ishga tushirish uchun:
# yes/true/1 — barcha private foydalanuvchilar uchun ochiq.
BOT_ALLOW_ALL_USERS=

# (Ixtiyoriy) Audit log fayli yo'li — har bir bajarilgan komanda/prompt (kim, qaysi chat,
# rejim, matn) shu faylga qo'shib yoziladi. Bo'sh — faqat standart logga (journald/err.log).
# Misol: BOT_AUDIT_LOG=C:\ProgramData\remofy-bot\logs\audit.log   (Linux: /var/log/remofy-audit.log)
BOT_AUDIT_LOG=

# Gruppa whitelist — faqat shu chat ID'larida bot javob beradi (gruppa va supergruppa).
# Bo'sh qoldirilsa — bot gruppalarda umuman javob bermaydi (xavfsiz default).
# Gruppa ID'si manfiy son: -100xxxxxxxxxx (super), -xxxxxxxxx (oddiy gruppa).
# Misol: ALLOWED_CHAT_IDS=-1001234567890
ALLOWED_CHAT_IDS=

# --- Claude agent workspace ---
# Bot Claude'ni shu papkada ishga tushiradi. Shu yerda .mcp.json va .claude/settings.json bo'lishi mumkin.
# Bo'sh qoldirilsa: C:\Users\nbkab\OneDrive\Ishchi stol
BOT_WORKDIR=

# --- MCP servers ---
# GitHub MCP server uchun Personal Access Token. .mcp.json ichida ${GITHUB_PERSONAL_ACCESS_TOKEN} sifatida ishlatiladi.
# https://github.com/settings/tokens — repo, issues, pull_request scope'lari kerak.
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Bot persona ---
# Har Claude promptiga `--append-system-prompt` orqali qo'shiladi. Bo'sh qoldirilsa default Claude xulqi.
# Ko'p qatorli istasangiz, qo'sh tirnoq ichida yozing va `\n` ishlatib bo'ladi.
BOT_SYSTEM_PROMPT=
