# Database (web-ssh-backend bilan AYNAN bir xil)
DB_PATH=postgres://user:pass@localhost:5432/remofy?sslmode=disable
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Telegram bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Google OAuth (yangi Client yoki mavjudiga bot uchun redirect qo'shilgan)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=https://bot.example.com/auth/google/callback

# Bot HTTP server (OAuth callback uchun)
BOT_HTTP_PORT=8090
PUBLIC_BASE_URL=https://bot.example.com

# Telegram Mini App — input maydoni yonidagi menyu tugmasi shu URL'ni ochadi.
# Bo'sh qoldirilsa Mini App o'chiriladi.
WEB_APP_URL=https://remofy.musanna.uz

# Sessiya idle timeout (daqiqa). Bo'sh bo'lsa default 30
SESSION_IDLE_MINUTES=30
